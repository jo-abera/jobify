generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String?
  googleId  String?    @unique
  avatar    String?
  skills    Json       @default("[]")
  location  String?
  createdAt DateTime   @default(now())
  savedJobs SavedJob[]
}

model Job {
  id          String     @id @default(uuid())
  title       String
  company     String
  location    String
  salary      String?
  url         String     @unique
  description String
  type        String     @default("Full-time")
  source      String
  postedAt    DateTime   @default(now())
  savedBy     SavedJob[]
}

model SavedJob {
  id      String   @id @default(uuid())
  userId  String
  jobId   String
  status  String   @default("saved")
  savedAt DateTime @default(now())
  job     Job      @relation(fields: [jobId], references: [id])
  user    User     @relation(fields: [userId], references: [id])

  @@unique([userId, jobId])
}
